# ── Resend (contact form) ────────────────────────────────────────────────
# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxx

# Sender shown in the From: line. Use a verified-domain address once you
# have one set up at https://resend.com/domains, e.g. "Aravinthakshan
# <hello@yourdomain.com>". Until then, fall back to `onboarding@resend.dev`
# (only delivers to the address that owns the Resend account).
CONTACT_FROM_EMAIL="aravinthakshan <onboarding@resend.dev>"

# Where contact-form submissions are delivered.
CONTACT_TO_EMAIL=you@example.com

# Host inside the synthesized Message-ID values used for cross-side
# threading. Stays stable even without a verified domain — clients key
# threading on the string identity, not on deliverability.
CONTACT_MESSAGE_ID_HOST=yourdomain.com
